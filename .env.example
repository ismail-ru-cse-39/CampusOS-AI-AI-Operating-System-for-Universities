# Backend
PORT=8000
DATABASE_URL=postgresql+asyncpg://campusos:campusos@localhost:5432/campusos
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000

# LLM — auto-enables OpenAI when key is set
OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
DEFAULT_UNIVERSITY_PLAN=starter
DEFAULT_UNIVERSITY_SLUG=demo-university
USAGE_HARD_CAP_DAILY_LLM_CALLS=100000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Security
ENVIRONMENT=development

# SSO / OIDC — set all three to enable university SSO
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=
OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
AUTH_DEV_LOGIN_ENABLED=true

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@campusos.edu

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Webhooks
TEAMS_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Neo4j (optional graph backend)
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Background worker — set true when Redis + Celery worker are running
CELERY_ENABLED=false
